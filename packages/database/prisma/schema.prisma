generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm, vector]
}

// ============================================================================
// SCHEMA DOMAIN OWNERSHIP MAP
// ============================================================================
// Audit / Events        owns: AuditLog, BookingStateHistory
// Identity / Auth       owns: User, Session, DeviceToken, IdentityDocument,
//                             UserPreferences, FavoriteListing
// Listings / Inventory  owns: Listing, Category, Availability, ListingContent,
//                             ListingVersion, CategoryAttributeDefinition,
//                             ListingAttributeValue, InventoryUnit,
//                             AvailabilitySlot, CancellationPolicy, ConditionReport
// Organizations         owns: Organization, OrganizationMember
// Bookings              owns: Booking, FxRateSnapshot, BookingPriceBreakdown
// Reviews & Trust       owns: Review, TrustScore, ReputationScore
// Payments & Finance    owns: Payment, Refund, DepositHold, Payout,
//                             LedgerEntry, EscrowTransaction
// Insurance             owns: InsurancePolicy, InsuranceClaim
// Notifications         owns: Notification, EmailTemplate, DeviceToken
// Messaging             owns: Conversation, Message, ConversationParticipant,
//                             MessageReadReceipt
// Disputes              owns: Dispute, DisputeEvidence, DisputeResponse,
//                             DisputeTimelineEvent, DisputeResolution, DisputeEscalation
// Policy & Compliance   owns: TaxRule, PolicyRule, PolicyAuditLog, ComplianceRecord,
//                             InsurancePolicy, TaxPolicy, CountryPolicyPack
// Platform Config       owns: CurrencyConfig, LocaleConfig, CountryConfig,
//                             PricingRule, RegionConfig, HostActivationCampaign
// Analytics & Metrics   owns: PlatformMetric, MarketplaceHealthMetric,
//                             DemandForecast, DemandSignal, MarketOpportunity,
//                             SearchEvent, UserSearchProfile, ServiceHealthCheck,
//                             AnomalyDetection, ExpansionSimulation
// AI & Concierge        owns: AiConversation, AiConversationTurn,
//                             PricingRecommendation
// Fraud & Moderation    owns: FraudSignal, DeviceFingerprint, ModerationAction
// Inventory Graph       owns: InventoryGraphNode, InventoryGraphEdge
// ============================================================================

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT / EVENTS
// Owner: platform-engineering  CODEOWNERS: @rental/platform-engineering
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  oldValues  String?
  newValues  String?
  metadata   String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation("AuditLogs", fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// IDENTITY / AUTH
// Owner: auth-team  CODEOWNERS: @rental/auth-team
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                         String                    @id @default(cuid())
  email                      String                    @unique
  username                   String                    @unique
  passwordHash               String?
  firstName                  String?
  lastName                   String?
  dateOfBirth                DateTime?
  phone                      String?
  profilePhotoUrl            String?
  bio                        String?
  role                       UserRole                  @default(USER)
  status                     UserStatus                @default(ACTIVE)
  isActive                   Boolean                   @default(true)
  averageRating              Float?                    @default(0)
  totalReviews               Int                       @default(0)
  responseRate               Float?
  responseTime               String?
  stripeCustomerId           String?
  stripeConnectId            String?
  stripeChargesEnabled       Boolean?
  stripePayoutsEnabled       Boolean?
  stripeOnboardingComplete   Boolean?
  emailVerified              Boolean                   @default(false)
  phoneVerified              Boolean?
  mfaEnabled                 Boolean?
  emailVerificationToken     String?
  passwordResetToken         String?
  passwordResetExpires       DateTime?
  lastLoginAt                DateTime?
  lastLoginIp                String?
  mfaSecret                  String?
  mfaBackupCodes             String[]
  idVerificationStatus       String?
  idVerificationUrl          String?
  governmentIdNumber         String?
  loginAttempts              Int                       @default(0)
  lockedUntil                DateTime?
  googleId                   String?                   @unique
  appleId                    String?                   @unique
  addressLine1               String?
  addressLine2               String?
  city                       String?
  state                      String?
  postalCode                 String?
  country                    String?
  subscriptionStatus         String?
  subscriptionId             String?
  subscriptionPlan           String?
  deletedAt                  DateTime?
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  aiConversations            AiConversation[]          @relation("AiConversations")
  auditLogs                  AuditLog[]                @relation("AuditLogs")
  bookingsOwned              Booking[]                 @relation("BookingsOwned")
  bookings                   Booking[]                 @relation("BookingRenter")
  conditionReportsCreated    ConditionReport[]         @relation("ConditionReportCreator")
  conversationParticipations ConversationParticipant[]
  deviceFingerprints         DeviceFingerprint[]       @relation("DeviceFingerprints")
  deviceTokens               DeviceToken[]
  disputeResponses           DisputeResponse[]
  disputesAssigned           Dispute[]                 @relation("DisputeAssignee")
  disputesDefended           Dispute[]                 @relation("DisputeDefendant")
  disputesInitiated          Dispute[]                 @relation("DisputeInitiator")
  favoriteListings           FavoriteListing[]
  identityDocuments          IdentityDocument[]
  insurancePoliciesOwned     InsurancePolicy[]         @relation("InsurancePolicyOwner")
  listingVersionsAuthored    ListingVersion[]          @relation("ListingVersionAuthor")
  messageReadReceipts        MessageReadReceipt[]
  messagesSent               Message[]                 @relation("MessageSender")
  notifications              Notification[]
  members                    OrganizationMember[]      @relation("UserMembers")
  organizations              Organization[]            @relation("OrganizationOwners")
  payouts                    Payout[]
  listings                   Listing[]                 @relation("Listings")
  reputationScore            ReputationScore?          @relation("ReputationScore")
  reviewsReceived            Review[]                  @relation("ReviewReceived")
  reviewsGiven               Review[]                  @relation("ReviewGiven")
  searchEvents               SearchEvent[]             @relation("UserSearchEvents")
  sessions                   Session[]
  userPreferences            UserPreferences?
  searchProfile              UserSearchProfile?        @relation("SearchProfile")
  taxForms                   TaxForm[]

  @@index([deletedAt])
  @@index([status])
  @@index([role])
  @@index([phone])
  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// LISTINGS & INVENTORY
// Owner: listings-team  CODEOWNERS: @rental/listings-team
// ─────────────────────────────────────────────────────────────────────────────

model Listing {
  id                     String                   @id @default(cuid())
  title                  String
  slug                   String                   @unique
  description            String?
  address                String
  city                   String
  state                  String
  zipCode                String
  country                String
  latitude               Float?
  longitude              Float?
  type                   PropertyType
  bookingMode            BookingMode              @default(REQUEST)
  status                 PropertyStatus           @default(AVAILABLE)
  verificationStatus     VerificationStatus       @default(PENDING)
  condition              PropertyCondition?
  bedrooms               Int?
  bathrooms              Int?
  maxGuests              Int?
  basePrice              Decimal
  currency               String
  securityDeposit        Decimal?
  cleaningFee            Decimal?
  amenities              String[]
  features               String[]
  photos                 String[]
  rules                  String[]
  cancellationPolicyId   String?
  categoryId             String?
  organizationId         String?
  ownerId                String
  averageRating          Float?                   @default(0)
  totalReviews           Int                      @default(0)
  totalBookings          Int                      @default(0)
  /// @deprecated Use viewCount instead
  views                  Int                      @default(0)
  viewCount              Int                      @default(0)
  instantBookable        Boolean                  @default(false)
  minStayNights          Int                      @default(1)
  maxStayNights          Int?
  checkInTime            String?
  checkOutTime           String?
  weeklyDiscount         Int?
  monthlyDiscount        Int?
  serviceFee             Decimal?
  isActive               Boolean                  @default(true)
  featured               Boolean                  @default(false)
  lastBookedAt           DateTime?
  metadata               String?
  searchVector           Unsupported("tsvector")?
  embedding              Unsupported("vector")?
  deletedAt              DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  availability           Availability[]           @relation("PropertyAvailability")
  availabilitySlots      AvailabilitySlot[]       @relation("ListingAvailabilitySlots")
  bookings               Booking[]                @relation("BookingListing")
  conditionReports       ConditionReport[]
  conversations          Conversation[]           @relation("PropertyConversations")
  favorites              FavoriteListing[]
  insuranceClaims        InsuranceClaim[]         @relation("PropertyClaims")
  insurancePolicies      InsurancePolicy[]
  inventoryUnits         InventoryUnit[]          @relation("ListingInventory")
  attributeValues        ListingAttributeValue[]  @relation("ListingAttributes")
  contents               ListingContent[]         @relation("ListingContents")
  versions               ListingVersion[]         @relation("ListingVersions")
  pricingRecommendations PricingRecommendation[]  @relation("PricingRecs")
  pricingRules           PricingRule[]            @relation("ListingPricingRules")
  cancellationPolicy     CancellationPolicy?      @relation(fields: [cancellationPolicyId], references: [id])
  category               Category?                @relation(fields: [categoryId], references: [id])
  organization           Organization?            @relation(fields: [organizationId], references: [id])
  owner                  User                     @relation("Listings", fields: [ownerId], references: [id], onDelete: Cascade)
  reviews                Review[]                 @relation("ReviewListing")

  @@index([ownerId, status])
  @@index([categoryId, status])
  @@index([city, country])
  @@index([deletedAt])
  @@index([status, type])
  @@index([latitude, longitude])
  @@map("properties")
}

model Category {
  id                   String                        @id @default(cuid())
  name                 String                        @unique
  slug                 String                        @unique
  description          String?
  icon                 String?
  parentId             String?
  isActive             Boolean                       @default(true)
  active               Boolean                       @default(true)
  order                Int?
  pricingMode          PricingMode?
  searchableFields     String[]
  requiredFields       String[]
  templateSchema       String?
  dailyPrice           Decimal?
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  parent               Category?                     @relation("CategoryParent", fields: [parentId], references: [id])
  children             Category[]                    @relation("CategoryParent")
  attributeDefinitions CategoryAttributeDefinition[] @relation("CategoryAttributes")
  pricingRules         PricingRule[]                 @relation("CategoryPricingRules")
  listings             Listing[]

  @@map("categories")
}

// ─────────────────────────────────────────────────────────────────────────────
// ORGANIZATIONS
// Owner: platform-engineering  CODEOWNERS: @rental/platform-engineering
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id                 String               @id @default(cuid())
  name               String
  slug               String               @unique
  description        String?
  logo               String?
  logoUrl            String?
  website            String?
  email              String?
  phone              String?
  address            String?
  city               String?
  state              String?
  zipCode            String?
  country            String?
  ownerId            String?
  stripeConnectId    String?
  businessType       String?
  status             OrganizationStatus   @default(ACTIVE)
  verificationStatus VerificationStatus   @default(PENDING)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  members            OrganizationMember[]
  owner              User?                @relation("OrganizationOwners", fields: [ownerId], references: [id])
  listings           Listing[]

  @@index([ownerId])
  @@map("organizations")
}

model OrganizationMember {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole @default(MEMBER)
  joinedAt       DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation("UserMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

// ─────────────────────────────────────────────────────────────────────────────
// BOOKINGS  (critical path — all changes require CODEOWNERS approval)
// Owner: bookings-team  CODEOWNERS: @rental/bookings-team
// ─────────────────────────────────────────────────────────────────────────────

model Booking {
  id                 String                  @id @default(cuid())
  listingId          String
  renterId           String
  ownerId            String
  startDate          DateTime
  endDate            DateTime
  basePrice          Decimal
  securityDeposit    Decimal?
  cleaningFee        Decimal?
  serviceFee         Decimal?
  taxAmount          Decimal?
  totalPrice         Decimal
  currency           String
  status             BookingStatus           @default(PENDING)
  paymentIntentId    String?
  chargeId           String?
  refundId           String?
  specialRequests    String?
  guestNotes         String?
  ownerNotes         String?
  checkInTime        String?
  checkOutTime       String?
  ownerEarnings      Decimal?
  platformFee        Decimal?
  depositAmount      Decimal?
  guestCount         Int                     @default(1)
  notes              String?
  metadata           String?
  cancelledAt        DateTime?
  completedAt        DateTime?
  cancellationReason String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  archived_at        DateTime?
  availabilitySlots  AvailabilitySlot[]      @relation("BookingAvailabilitySlots")
  priceBreakdown     BookingPriceBreakdown[] @relation("BookingPriceBreakdown")
  stateHistory       BookingStateHistory[]
  bookingOwner       User                    @relation("BookingsOwned", fields: [ownerId], references: [id], map: "bookings_bookingOwner_fkey")
  listing            Listing                 @relation("BookingListing", fields: [listingId], references: [id], map: "bookings_listingId_fkey")
  renter             User                    @relation("BookingRenter", fields: [renterId], references: [id], map: "bookings_renter_fkey")
  conditionReports   ConditionReport[]
  conversations      Conversation[]
  depositHolds       DepositHold[]
  disputes           Dispute[]
  escrowTransactions EscrowTransaction[]     @relation("BookingEscrow")
  fxRateSnapshot     FxRateSnapshot?         @relation("BookingFxRate")
  insuranceClaims    InsuranceClaim[]
  insurancePolicies  InsurancePolicy[]
  ledgerEntries      LedgerEntry[]
  payments           Payment[]
  refunds            Refund[]
  reviews            Review[]

  @@index([renterId, status])
  @@index([ownerId, status])
  @@index([listingId])
  @@index([listingId, startDate, endDate])
  @@index([status])
  @@index([createdAt])
  @@index([archived_at])
  @@map("bookings")
}

// ─────────────────────────────────────────────────────────────────────────────
// REVIEWS & TRUST
// Owner: trust-team  CODEOWNERS: @rental/trust-team
// ─────────────────────────────────────────────────────────────────────────────

model Review {
  id                  String       @id @default(cuid())
  bookingId           String?
  listingId           String?
  reviewerId          String
  revieweeId          String
  type                ReviewType
  rating              Int          @db.SmallInt
  overallRating       Int?         @db.SmallInt
  accuracyRating      Int?         @db.SmallInt
  communicationRating Int?         @db.SmallInt
  cleanlinessRating   Int?         @db.SmallInt
  valueRating         Int?         @db.SmallInt
  locationRating      Int?         @db.SmallInt
  checkInRating       Int?         @db.SmallInt
  comment             String?
  response            String?
  status              ReviewStatus @default(PUBLISHED)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  // SetNull preserves reviews for integrity even if the booking is hard-deleted (G9 fix).
  booking             Booking?     @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  listing             Listing?     @relation("ReviewListing", fields: [listingId], references: [id])
  reviewee            User         @relation("ReviewReceived", fields: [revieweeId], references: [id])
  reviewer            User         @relation("ReviewGiven", fields: [reviewerId], references: [id])

  @@unique([bookingId, reviewerId, type])
  @@index([reviewerId])
  @@index([revieweeId])
  @@index([listingId, createdAt])
  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENTS & FINANCE  (all changes require security-team + payments-team review)
// Owner: payments-team  CODEOWNERS: @rental/payments-team @rental/security-team
// ─────────────────────────────────────────────────────────────────────────────

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String
  amount                Decimal
  currency              String
  status                PaymentStatus @default(PENDING)
  paymentMethod         String?
  paymentIntentId       String        @unique
  /// @deprecated Use paymentIntentId instead
  stripePaymentIntentId String?
  chargeId              String?
  stripeChargeId        String?
  refundId              String?
  fee                   Decimal?
  netAmount             Decimal?
  processedAt           DateTime?
  failureReason         String?
  description           String?
  metadata              String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  // Restrict prevents hard-deleting a booking that has payment records (G9 fix).
  booking               Booking       @relation(fields: [bookingId], references: [id], onDelete: Restrict)

  @@index([bookingId, status])
  @@map("payments")
}

model Refund {
  id          String       @id @default(cuid())
  bookingId   String
  amount      Decimal
  currency    String
  status      RefundStatus @default(PENDING)
  refundId    String       @unique
  reason      String?
  description String?
  metadata    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  // Restrict prevents hard-deleting a booking that has refund records (G9 fix).
  booking     Booking      @relation(fields: [bookingId], references: [id], onDelete: Restrict)

  @@index([bookingId])
  @@map("refunds")
}

model DepositHold {
  id              String        @id @default(cuid())
  bookingId       String
  amount          Decimal
  currency        String
  status          DepositStatus @default(PENDING)
  stripeId        String?
  paymentIntentId String?
  expiresAt       DateTime?
  releasedAt      DateTime?
  capturedAt      DateTime?
  deductedAmount  Decimal?
  metadata        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  // Restrict prevents hard-deleting a booking that has deposit holds (G9 fix).
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Restrict)

  @@index([bookingId])
  @@map("deposit_holds")
}

model Payout {
  id          String       @id @default(cuid())
  ownerId     String
  amount      Decimal
  currency    String
  status      PayoutStatus @default(PENDING)
  /// @deprecated Use transferId instead — Stripe transfer ID
  stripeId    String?
  transferId  String?      @unique
  paidAt      DateTime?
  processedAt DateTime?
  metadata    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  owner       User         @relation(fields: [ownerId], references: [id])

  @@index([ownerId, status])
  @@map("payouts")
}

model LedgerEntry {
  id              String            @id @default(cuid())
  bookingId       String?
  accountId       String
  accountType     AccountType
  side            LedgerSide
  transactionType TransactionType
  amount          Decimal
  currency        String
  description     String
  status          LedgerEntryStatus @default(PENDING)
  metadata        String?
  referenceId     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  // SetNull preserves ledger entries for accounting even if the booking is hard-deleted (G9 fix).
  booking         Booking?          @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([accountId, accountType])
  @@map("ledger_entries")
}

model TaxForm {
  id          String   @id @default(cuid())
  userId      String
  type        String // e.g. 'FORM_1099'
  year        Int
  formData    Json
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, year])
  @@map("tax_forms")
}

/// Stores the result of every Stripe Tax API calculation for audit, reconciliation,
/// and 1099/tax-form generation. One record per booking checkout attempt.
model TaxCalculation {
  id              String   @id @default(cuid())
  bookingId       String?
  listingId       String?
  stripeTaxId     String? // Stripe Tax calculation ID (tax.calculations.id)
  amount          Decimal // Pre-tax amount in minor units
  taxAmount       Decimal // Tax portion
  totalAmount     Decimal // amount + taxAmount
  taxRate         Float    @default(0)
  currency        String   @db.VarChar(3)
  jurisdiction    String? // Primary tax jurisdiction name
  taxBreakdown    Json     @default("[]") // Array of TaxLineItem
  customerAddress Json? // Snapshot of customer address used for calculation
  taxable         Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([bookingId])
  @@index([listingId])
  @@index([createdAt])
  @@map("tax_calculations")
}

model Availability {
  id         String             @id @default(cuid())
  propertyId String
  startDate  DateTime
  endDate    DateTime
  status     AvailabilityStatus @default(AVAILABLE)
  price      Decimal?
  notes      String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  property   Listing            @relation("PropertyAvailability", fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, startDate, endDate])
  @@index([propertyId, status])
  @@map("availability")
}

model ListingContent {
  id          String   @id @default(cuid())
  listingId   String
  locale      String   @default("en")
  title       String
  description String
  rules       String?
  highlights  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  listing     Listing  @relation("ListingContents", fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, locale])
  @@index([locale])
  @@map("listing_contents")
}

model ListingVersion {
  id          String   @id @default(cuid())
  listingId   String
  version     Int
  snapshot    String
  changedBy   String
  changeNotes String?
  createdAt   DateTime @default(now())
  author      User     @relation("ListingVersionAuthor", fields: [changedBy], references: [id])
  listing     Listing  @relation("ListingVersions", fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, version])
  @@index([listingId, createdAt])
  @@map("listing_versions")
}

model CategoryAttributeDefinition {
  id           String                  @id @default(cuid())
  categoryId   String
  slug         String
  label        String
  fieldType    String
  isRequired   Boolean                 @default(false)
  isSearchable Boolean                 @default(false)
  isFilterable Boolean                 @default(false)
  options      String?
  validation   String?
  displayOrder Int                     @default(0)
  unit         String?
  helpText     String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  category     Category                @relation("CategoryAttributes", fields: [categoryId], references: [id], onDelete: Cascade)
  values       ListingAttributeValue[] @relation("AttributeDefinitionValues")

  @@unique([categoryId, slug])
  @@index([categoryId, displayOrder])
  @@map("category_attribute_definitions")
}

model ListingAttributeValue {
  id                    String                      @id @default(cuid())
  listingId             String
  attributeDefinitionId String
  value                 String
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  attributeDefinition   CategoryAttributeDefinition @relation("AttributeDefinitionValues", fields: [attributeDefinitionId], references: [id], onDelete: Cascade)
  listing               Listing                     @relation("ListingAttributes", fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, attributeDefinitionId])
  @@index([attributeDefinitionId, value])
  @@map("listing_attribute_values")
}

model InventoryUnit {
  id                String             @id @default(cuid())
  listingId         String
  sku               String
  label             String?
  isActive          Boolean            @default(true)
  metadata          String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  availabilitySlots AvailabilitySlot[] @relation("UnitAvailability")
  listing           Listing            @relation("ListingInventory", fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, sku])
  @@index([listingId, isActive])
  @@map("inventory_units")
}

model AvailabilitySlot {
  id              String                 @id @default(cuid())
  listingId       String
  inventoryUnitId String?
  startTime       DateTime
  endTime         DateTime
  status          AvailabilitySlotStatus @default(AVAILABLE)
  price           Decimal?
  currency        String
  bookingId       String?
  notes           String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  version         Int                    @default(0)
  booking         Booking?               @relation("BookingAvailabilitySlots", fields: [bookingId], references: [id])
  inventoryUnit   InventoryUnit?         @relation("UnitAvailability", fields: [inventoryUnitId], references: [id])
  listing         Listing                @relation("ListingAvailabilitySlots", fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, inventoryUnitId, startTime, endTime])
  @@index([listingId, startTime, endTime])
  @@index([inventoryUnitId, startTime])
  @@index([status])
  @@map("availability_slots")
}

model FxRateSnapshot {
  id             String   @id @default(cuid())
  bookingId      String   @unique
  baseCurrency   String
  targetCurrency String
  rate           Decimal
  rateSource     String
  capturedAt     DateTime @default(now())
  booking        Booking  @relation("BookingFxRate", fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([baseCurrency, targetCurrency, capturedAt])
  @@map("fx_rate_snapshots")
}

model BookingPriceBreakdown {
  id        String        @id @default(cuid())
  bookingId String
  lineType  PriceLineType
  label     String
