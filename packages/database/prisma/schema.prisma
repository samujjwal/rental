// ─────────────────────────────────────────────────────────────────────────────
// Event Sourcing / Audit Trail
// Owner: platform-team  CODEOWNERS: @rental/platform-team
// ─────────────────────────────────────────────────────────────────────────────

/// Append-only log of all domain events. Never updated or deleted.
model EventStore {
  id            String   @id @default(cuid())
  aggregateId   String
  aggregateType String
  eventType     String
  version       Int
  /// JSON-stringified event payload
  payload       String
  /// Structured metadata including correlationId, causationId, userId, etc.
  metadata      Json     @default("{}")
  timestamp     DateTime @default(now())

  @@index([aggregateId, version])
  @@index([aggregateId, aggregateType])
  @@index([eventType, timestamp])
  @@index([timestamp])
  @@map("event_store")
}

/// Point-in-time snapshots of aggregate state to speed up replay.
model EventSnapshot {
  id            String   @id @default(cuid())
  aggregateId   String
  aggregateType String
  version       Int
  /// JSON-stringified aggregate state at snapshot time
  state         String
  timestamp     DateTime @default(now())

  @@unique([aggregateId, version])
  @@index([aggregateId, version])
  @@map("event_snapshots")
}

/// Lightweight ledger for tracking per-user AI token usage for cost governance.
model AiUsageLedger {
  id                 String   @id @default(cuid())
  userId             String
  organizationId     String?
  promptId           String
  promptVersion      String
  model              String
  inputTokens        Int
  outputTokens       Int
  totalTokens        Int
  /// Estimated cost in USD cents (integer to avoid float rounding)
  estimatedCostCents Int      @default(0)
  createdAt          DateTime @default(now())

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@index([promptId, createdAt])
  @@map("ai_usage_ledger")
}
