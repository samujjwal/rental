# Test Environment Configuration
NODE_ENV=test

# Database Configuration
DATABASE_URL=postgresql://test:test@localhost:5432/rental_test

# JWT Configuration
JWT_SECRET=test-jwt-secret-key-for-testing-only
JWT_EXPIRATION=1h

# Stripe Sandbox Configuration
STRIPE_SECRET_KEY=sk_test_51N...
STRIPE_PUBLISHABLE_KEY=pk_test_51N...
STRIPE_WEBHOOK_SECRET=whsec_test_...
STRIPE_API_VERSION=2023-10-16

# Stripe Sandbox Test Cards (for testing)
STRIPE_TEST_CARD_NUMBER=4242424242424242
STRIPE_TEST_CARD_DECLINE=4000000000000002
STRIPE_TEST_CARD_INSUFFICIENT_FUNDS=4000000000009995
STRIPE_TEST_CARD_EXPIRED=4000000000000069

# MinIO S3-Compatible Storage Configuration
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=test-bucket
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Ceph S3 Configuration (alternative to MinIO)
# S3_ENDPOINT=http://localhost:7480
# S3_ACCESS_KEY=cephadmin
# S3_SECRET_KEY=cephadmin
# S3_BUCKET_NAME=test-bucket

# Email Configuration (Mailhog for testing)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=test@rental.local

# Redis Configuration
REDIS_URL=redis://localhost:6379

# WebSocket Configuration
WS_PORT=8080

# Logging
LOG_LEVEL=debug

# Feature Flags
ENABLE_PAYMENTS=true
ENABLE_NOTIFICATIONS=true
ENABLE_REALTIME=true

# Test Data Configuration
TEST_SEED_DATA=true
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=test123456
