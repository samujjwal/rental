{
  "name": "@rental-portal/web",
  "version": "1.0.0",
  "description": "GharBatai Rentals - React Router v7 Web Application",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "vite preview --host 127.0.0.1 --port 3401 --strictPort --outDir build/client",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "eslint app --ext .ts,.tsx",
    "format": "prettier --write \"{app,tests,e2e}/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node ./scripts/run-playwright-suite.mjs",
    "test:e2e:core": "node ./scripts/run-playwright-suite.mjs core",
    "test:e2e:chromium": "PLAYWRIGHT_DEFAULT_PROJECT=chromium node ./scripts/run-playwright-suite.mjs core --reporter=list,html",
    "test:e2e:local": "PLAYWRIGHT_DEFAULT_PROJECT=chromium node ./scripts/run-playwright-suite.mjs core --config=playwright.local.config.ts --reporter=list",
    "test:e2e:comprehensive": "node ./scripts/run-playwright-suite.mjs comprehensive",
    "test:e2e:full": "node ./scripts/run-playwright-suite.mjs full",
    "test:e2e:debug": "PLAYWRIGHT_INCLUDE_DEBUG=true node ./scripts/run-playwright-suite.mjs debug",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@rental-portal/shared-types": "workspace:*",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.7.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.13.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.30.0",
    "i18next": "^25.8.13",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^16.5.4",
    "react-leaflet": "^5.0.0",
    "react-router": "^7.13.0",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "stripe": "^20.3.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.0",
    "@react-router/dev": "^7.13.0",
    "@react-router/node": "^7.13.0",
    "@react-router/serve": "^7.13.0",
    "@remix-run/testing": "^2.17.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
