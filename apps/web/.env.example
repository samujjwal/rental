# API Configuration
VITE_API_URL=http://localhost:3400
# WebSocket URL for real-time features (booking updates, notifications, messaging)
# In production, set to wss://your-api-domain.com
VITE_WS_URL=ws://localhost:3001
# Development Login (password for fallback login; secret is fetched at runtime from API)
# VITE_DEV_LOGIN_SECRET is intentionally not set here — the secret is now fetched via
# GET /auth/dev-config to prevent it from being embedded in the compiled JS bundle.
VITE_DEV_LOGIN_PASSWORD=password123
# Stripe Configuration (client-side)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Environment
NODE_ENV=development
