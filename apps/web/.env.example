# API Configuration
VITE_API_URL=http://localhost:3400
# Development Login (must match API's DEV_LOGIN_SECRET in apps/api/.env)
# The secret is used for fast dev login without password; only works when API NODE_ENV=development
VITE_DEV_LOGIN_SECRET=e2e-test-secret-12345
VITE_DEV_LOGIN_PASSWORD=password123
# Stripe Configuration (client-side)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Environment
NODE_ENV=development
