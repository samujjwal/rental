{
  "name": "gharbatai-rentals",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "description": "GharBatai Rentals - Multi-category marketplace platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "./setup-env.sh",
    "env:start": "./scripts/env/start-env.sh",
    "dev": "./scripts/dev/start-dev.sh",
    "dev:apps": "turbo run dev",
    "dev:api": "pnpm --filter @rental-portal/api run dev",
    "dev:web": "pnpm --filter @rental-portal/web run dev",
    "dev:mobile": "pnpm --filter rental-portal-mobile run start",
    "build": "turbo run build",
    "test": "./scripts/test/run-tests.sh",
    "test:unit": "./scripts/test/run-tests.sh unit",
    "test:integration": "./scripts/test/run-tests.sh integration",
    "test:e2e": "./scripts/test/run-e2e.sh",
    "test:coverage": "./scripts/test/run-coverage.sh project",
    "test:coverage:full": "./scripts/test/run-coverage.sh full",
    "test:coverage:fast": "./scripts/test/run-coverage.sh fast",
    "test:security": "./scripts/test/run-tests.sh security",
    "test:performance": "./scripts/test/run-tests.sh performance",
    "test:all": "./scripts/test/run-tests.sh all",
    "test:watch": "./scripts/test/run-tests.sh all dev --watch",
    "test:verbose": "./scripts/test/run-tests.sh all dev --verbose",
    "test:strict": "node scripts/test/test-strict.mjs",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "arch-lint": "turbo run arch-lint",
    "check-deps": "depcruise --config .dependency-cruiser.cjs --output-dot dependency-graph.dot --output-type dot src",
    "check-circular": "depcruise --config .dependency-cruiser.cjs src --output-type err-long",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @rental-portal/database run generate",
    "db:migrate": "pnpm --filter @rental-portal/database run migrate:deploy",
    "db:studio": "pnpm --filter @rental-portal/database run studio",
    "db:seed": "pnpm --filter @rental-portal/database run seed",
    "guardrails": "./scripts/ci/run-guardrails.sh",
    "audit:security": "./scripts/test/run-security-audit.sh",
    "deploy": "sudo ./scripts/deploy/deploy.sh production",
    "deploy:prod": "sudo ./scripts/deploy/deploy.sh production",
    "backup": "./scripts/backup/backup.sh production",
    "backup:prod": "./scripts/backup/backup.sh production",
    "validate": "./validate-build.sh",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "@opensearch-project/opensearch": "^3.5.0",
    "@types/node": "^25.1.0",
    "dependency-cruiser": "^17.3.8",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.1",
    "prettier": "^3.8.1",
    "puppeteer": "^24.39.0",
    "redis": "^5.11.0",
    "sharp": "^0.34.5",
    "turbo": "^2.8.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
