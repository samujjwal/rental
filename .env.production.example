# ===========================================
# Core runtime
# ===========================================
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
VITE_API_URL=/api

# ===========================================
# Database / Cache
# ===========================================
DATABASE_URL=postgresql://postgres:change_me@db-host:5432/gharbatai?schema=public
REDIS_URL=redis://:change_me@redis-host:6379

# ===========================================
# Auth
# ===========================================
JWT_SECRET=change_me_with_64_plus_random_chars
JWT_REFRESH_SECRET=change_me_with_64_plus_random_chars

# ===========================================
# Optional integrations
# ===========================================
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_CDN=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SENDGRID_API_KEY=
SENTRY_DSN=

# ===========================================
# Deployment behavior
# ===========================================
# Set to true to skip local pg_dump backup step in scripts/deploy.sh
SKIP_DB_BACKUP=true
